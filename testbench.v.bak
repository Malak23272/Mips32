module mips32_tb();
reg clock,reset;
wire [31:0] ALU_result;
MIPS DUT(clock,reset,ALU_result);
always #5 clock=~clock;
initial
begin
reset=0;
clock=0;
#10;
//start to accept signals
reset=1;// making zeros for the whole program
#10;
reset=0;//start execution
#400;
reset=1;// making zeros for the whole program
#10;
reset=0;//start execution
#400;
reset=1;// making zeros for the whole program
#10;
reset=0;//start execution
#400;
$finish;
end
endmodule




